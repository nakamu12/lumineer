# =============================================================================
# AI Processing — local development (uv run python main.py)
# Copy to ai/.env.local and fill in values.
# These are used when running the AI service directly (not via docker compose).
# When running via docker compose --profile app, docker-compose environment:
# section overrides QDRANT_URL with the Docker-internal hostname.
#
# Note: OPENAI_API_KEY and other shared settings are read from the root
# .env.local via Pydantic Settings. Only add service-specific overrides here.
# =============================================================================

# Qdrant — use localhost + the port set in root QDRANT_PORT (default: 6333)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=   # required in prod only
