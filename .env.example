# =============================================================================
# App settings
# =============================================================================

APP_ENV=dev

# =============================================================================
# OpenAI (required)
# =============================================================================

OPENAI_API_KEY=

# =============================================================================
# Ports
# Override any port if it conflicts with another service on your machine.
# =============================================================================

# POSTGRES_PORT=5432
# QDRANT_PORT=6333
# QDRANT_GRPC_PORT=6334
# GATEWAY_PORT=3000
# BACKEND_PORT=3001
# AI_PORT=8001
# FRONTEND_PORT=5173
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3002
# LANGFUSE_PORT=3003

# =============================================================================
# PostgreSQL
# Docker (via docker compose --profile app): overridden to @postgres:5432
# Local bun dev (infra-only mode):           use @localhost:<POSTGRES_PORT>
# =============================================================================

DATABASE_URL=postgres://lumineer:lumineer@localhost:5432/lumineer

# =============================================================================
# Qdrant
# Docker (via docker compose --profile app): overridden to http://qdrant:6333
# Local uv run (infra-only mode):            use http://localhost:<QDRANT_PORT>
# =============================================================================

QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=   # required in prod only

# =============================================================================
# AI Processing settings
# =============================================================================

EMBEDDING_MODEL=text-embedding-3-large
RERANKER_STRATEGY=none
CONTEXT_FORMAT=json

# =============================================================================
# JWT Auth
# =============================================================================

JWT_SECRET=dev-secret-change-in-prod-min-16chars
# JWT_ACCESS_EXPIRES=15m   # default: 15m
# JWT_REFRESH_EXPIRES=7d   # default: 7d

# =============================================================================
# Langfuse (optional — start with: docker compose --profile observability up)
# =============================================================================

# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3003

# =============================================================================
# MCP Server OAuth 2.1 (optional — start with: docker compose --profile mcp up)
#
# Enables authentication for the MCP server at /mcp.
# In dev mode (KEYCLOAK_URL unset): MCP tools are accessible without auth.
# In prod (MCP_REQUIRE_AUTH=true): Bearer tokens from Keycloak are required.
#
# Admin console: http://localhost:8080 (admin / admin)
# =============================================================================

# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=lumineer
# MCP_REQUIRE_AUTH=false
# MCP_RESOURCE_SERVER_URL=https://your-domain.run.app/mcp   # required in prod when MCP_REQUIRE_AUTH=true
# KEYCLOAK_PORT=8080
