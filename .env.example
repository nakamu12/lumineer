# =============================================================================
# App settings
# =============================================================================

APP_ENV=dev

# =============================================================================
# OpenAI (required)
# =============================================================================

OPENAI_API_KEY=

# =============================================================================
# Qdrant (dev: auto-configured via docker-compose)
# =============================================================================

# QDRANT_URL=http://qdrant:6333   # set automatically in docker-compose
# QDRANT_API_KEY=                 # required in prod only

# =============================================================================
# AI Processing settings
# =============================================================================

EMBEDDING_MODEL=text-embedding-3-large
RERANKER_STRATEGY=none
CONTEXT_FORMAT=json

# =============================================================================
# PostgreSQL (dev: auto-configured via docker-compose)
# =============================================================================

# DATABASE_URL=postgres://lumineer:lumineer@localhost:5432/lumineer  # set automatically in docker-compose
DATABASE_URL=postgres://lumineer:lumineer@localhost:5432/lumineer

# =============================================================================
# JWT Auth
# =============================================================================

JWT_SECRET=your-secret-key-min-16-characters
# JWT_ACCESS_EXPIRES=15m   # default: 15m
# JWT_REFRESH_EXPIRES=7d   # default: 7d

# =============================================================================
# Langfuse (optional — start with: docker compose --profile observability up)
# =============================================================================

# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3002
