{
  "id": null,
  "uid": "lumineer-observability",
  "title": "Lumineer Observability",
  "tags": ["lumineer", "llmops", "ai-processing", "qdrant", "postgres"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "agent",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(ai_llm_requests_total, agent)",
        "query": { "query": "label_values(ai_llm_requests_total, agent)", "refId": "StandardVariableQuery" },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "label": "Agent",
        "refresh": 2,
        "sort": 1,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(ai_tokens_used_total, model)",
        "query": { "query": "label_values(ai_tokens_used_total, model)", "refId": "StandardVariableQuery" },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "label": "Model",
        "refresh": 2,
        "sort": 1,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "LLM Performance",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "LLM Requests / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ai_llm_requests_total{agent=~\"$agent\"}[1m])",
          "legendFormat": "{{agent}} — {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "LLM Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(ai_llm_latency_seconds_bucket{agent=~\"$agent\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(ai_llm_latency_seconds_bucket{agent=~\"$agent\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(ai_llm_latency_seconds_bucket{agent=~\"$agent\"}[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        }
      }
    },
    {
      "id": 3,
      "title": "Estimated Cost (USD / min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ai_llm_cost_usd_total{model=~\"$model\"}[1m]) * 60",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "semi-dark-orange" }
        }
      }
    },
    {
      "id": 200,
      "title": "Error & Agent Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 4,
      "title": "LLM Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ai_llm_requests_total{status=\"error\",agent=~\"$agent\"}[5m]) / rate(ai_llm_requests_total{agent=~\"$agent\"}[5m]) * 100",
          "legendFormat": "{{agent}} error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        }
      }
    },
    {
      "id": 5,
      "title": "Agent Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (agent) (ai_llm_requests_total)",
          "legendFormat": "{{agent}}"
        }
      ],
      "options": {
        "pieType": "pie",
        "displayLabels": ["percent", "name"]
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 6,
      "title": "Agent Handoffs",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(ai_agent_handoffs_total) by (from_agent, to_agent)",
          "legendFormat": "{{from_agent}} → {{to_agent}}"
        }
      ],
      "options": {
        "pieType": "pie",
        "displayLabels": ["percent", "name"]
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 300,
      "title": "Token Usage",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 7,
      "title": "Token Consumption Rate (input vs output)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ai_tokens_used_total{model=~\"$model\"}[1m])",
          "legendFormat": "{{type}} — {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 8,
      "title": "Output / Input Token Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(ai_tokens_used_total{type=\"output\",model=~\"$model\"}) / sum(ai_tokens_used_total{type=\"input\",model=~\"$model\"})",
          "legendFormat": "output/input ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    },
    {
      "id": 400,
      "title": "Safety & Guardrails",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 9,
      "title": "Guardrail Triggers",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(ai_guardrail_triggers_total[5m])",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "dark-red" }
        }
      }
    },
    {
      "id": 10,
      "title": "PII Detections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(ai_pii_detections_total[5m])",
          "legendFormat": "{{entity_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "dark-orange" }
        }
      }
    },
    {
      "id": 500,
      "title": "Infrastructure",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }
    },
    {
      "id": 11,
      "title": "Cumulative Stats",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(ai_llm_requests_total)", "legendFormat": "Total Requests" },
        { "expr": "sum(ai_tokens_used_total{type=\"input\"})", "legendFormat": "Total Input Tokens" },
        { "expr": "sum(ai_tokens_used_total{type=\"output\"})", "legendFormat": "Total Output Tokens" },
        { "expr": "sum(ai_llm_cost_usd_total)", "legendFormat": "Total Cost (USD)" },
        { "expr": "sum(ai_guardrail_triggers_total)", "legendFormat": "Total Guardrail Triggers" },
        { "expr": "sum(ai_pii_detections_total)", "legendFormat": "Total PII Detected" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total Cost (USD)" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          },
          {
            "matcher": { "id": "byName", "options": "Total Guardrail Triggers" },
            "properties": [{
              "id": "thresholds",
              "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "red", "value": 1 }
                ]
              }
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Total PII Detected" },
            "properties": [{
              "id": "thresholds",
              "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 1 }
                ]
              }
            }]
          }
        ]
      }
    },
    {
      "id": 12,
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p95 — {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 600,
      "title": "Qdrant & PostgreSQL",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 }
    },
    {
      "id": 13,
      "title": "Qdrant — gRPC Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(app_grpc_responses_duration_seconds_bucket{job=\"qdrant\"}[5m])) by (le, endpoint))",
          "legendFormat": "p95 — {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 14,
      "title": "Qdrant — Collections & Points",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "app_info_collections_total{job=\"qdrant\"}", "legendFormat": "Collections" },
        { "expr": "app_info_points_total{job=\"qdrant\"}", "legendFormat": "Points" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 15,
      "title": "PostgreSQL — Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 60 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\", datname=\"lumineer\"}",
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 16,
      "title": "PostgreSQL — Database Size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 60 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{job=\"postgres\", datname=\"lumineer\"}",
          "legendFormat": "lumineer"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 17,
      "title": "PostgreSQL — Transactions (per second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 60 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{job=\"postgres\", datname=\"lumineer\"}[5m])",
          "legendFormat": "commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{job=\"postgres\", datname=\"lumineer\"}[5m])",
          "legendFormat": "rollbacks/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    }
  ],
  "schemaVersion": 39
}
