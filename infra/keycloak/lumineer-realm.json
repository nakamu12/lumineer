{
  "realm": "lumineer",
  "enabled": true,
  "displayName": "Lumineer",
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "accessTokenLifespan": 1800,
  "refreshTokenMaxReuse": 0,

  "clients": [
    {
      "clientId": "mcp-server",
      "name": "Lumineer MCP Resource Server",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "description": "MCP server resource — validates tokens but does not issue them"
    },
    {
      "clientId": "mcp-client",
      "name": "Lumineer MCP Client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "pkceCodeChallengeMethod": "S256",
      "redirectUris": [
        "http://localhost:*",
        "http://127.0.0.1:*"
      ],
      "webOrigins": [
        "http://localhost:*",
        "http://127.0.0.1:*"
      ],
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "false",
        "backchannel.logout.session.required": "true"
      },
      "description": "Public OAuth 2.1 client used by MCP clients (Claude Desktop, Cursor, etc.)"
    }
  ],

  "users": [
    {
      "username": "dev-user",
      "email": "dev@example.com",
      "firstName": "Dev",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
