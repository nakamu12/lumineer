# =============================================================================
# Backend — local development (bun dev)
# Copy to backend/.env.local and fill in values.
# These are used when running `bun dev` directly (not via docker compose).
# When running via docker compose --profile app, docker-compose environment:
# section overrides these with Docker-internal hostnames.
# =============================================================================

# PostgreSQL — use localhost + the port set in root POSTGRES_PORT (default: 5432)
DATABASE_URL=postgres://lumineer:lumineer@localhost:5432/lumineer

# AI Processing service — use localhost + the port set in root AI_PORT (default: 8001)
AI_PROCESSING_URL=http://localhost:8001

# JWT
JWT_SECRET=dev-secret-change-in-prod-min-16chars
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_EXPIRES=7d
